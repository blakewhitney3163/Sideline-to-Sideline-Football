{
  "name": "gridiron-dynasty",
  "productName": "Gridiron Dynasty",
  "version": "1.0.0",
  "description": "A professional football dynasty simulator",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "test": "vitest run",
    "simulate": "npm rebuild better-sqlite3 && node src/simulateSeason.js && .\\node_modules\\.bin\\electron-rebuild -v 42.4.0 --force && rmdir /s /q .webpack 2>nul & npm start",
    "import-madden": "npm rebuild better-sqlite3 && node src/importFromMadden.js && .\\node_modules\\.bin\\electron-rebuild -v 42.4.0 --force",
    "update-ratings": "npm rebuild better-sqlite3 && node src/updateRatings.js && .\\node_modules\\.bin\\electron-rebuild -v 42.4.0 --force",
    "import-players": "npm rebuild better-sqlite3 && node src/importPlayers.js && .\\node_modules\\.bin\\electron-rebuild -v 42.4.0 --force",
    "generate-icons": "node scripts/generate-icons.js"
  },
  "keywords": [],
  "author": {
    "name": "Blake Whitney",
    "email": "blakewhitney3163@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-webpack": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.4",
    "@types/react-window": "^1.8.8",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "42.4.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "node-loader": "^2.1.0",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1",
    "sharp": "^0.35.2",
    "style-loader": "^3.3.4",
    "to-ico": "^1.1.5",
    "ts-loader": "^9.6.0",
    "typescript": "~4.5.4",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "electron-squirrel-startup": "^1.0.1",
    "react-window": "^2.2.7",
    "zustand": "^5.0.14"
  }
}
